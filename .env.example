# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token

# Character.AI API Tokens (you can add multiple for rotation)
CHARACTERAI_TOKEN=your_characterai_token
CHARACTERAI_TOKEN_2=your_second_characterai_token
CHARACTERAI_TOKEN_3=your_third_characterai_token

# Character.AI Character ID
CHARACTERAI_CHARACTER_ID=your_characterai_character_id

# Other API Keys
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
CEREBRAS_API_KEY=your_cerebras_api_key
MISTRAL_API_KEY=your_mistral_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
CHATGPT_API_KEY=your_chatgpt_api_key

# GitHub configuration for saving channel preferences
GITHUB_TOKEN=your_github_token
GITHUB_REPO=username/repo

# Bot owner ID (Discord user ID)
BOT_OWNER_ID=your_discord_user_id

# YouTube API Key (for YouTube video features)
YOUTUBE_API_KEY=your_youtube_api_key

# Spotify API (optional - for Spotify music support)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Lavalink Configuration (optional - uses localhost if empty)
LAVALINK_HOST=your_lavalink_host_or_ip
LAVALINK_PASSWORD=your_lavalink_password

# OpenClaw 雲端視覺網頁操作 (Northflank)
OPENCLAW_API_URL=https://p01-openclaw-msa--rrp2s8sqd2zk.code.run
OPENCLAW_GATEWAY_PASSWORD=your_northflank_gateway_password